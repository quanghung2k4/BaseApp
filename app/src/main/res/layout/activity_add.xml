<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp" tools:context=".AddRoomActivity">
    <EditText android:id="@+id/etRoomId" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Mã phòng"/>
    <EditText android:id="@+id/etRoomName" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Tên phòng"/>
    <EditText android:id="@+id/etRoomPrice" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Giá thuê" android:inputType="numberDecimal"/>
    <androidx.appcompat.widget.SwitchCompat android:id="@+id/swRentedStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Đã thuê"/>
    <Button android:id="@+id/btnSave" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:layout_marginTop="16dp" android:text="Lưu"/>
</LinearLayout>